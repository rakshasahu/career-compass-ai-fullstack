# ──────────────────────────────────────────────
# Career Compass AI - Environment Variables
# ──────────────────────────────────────────────
# ⚠️  Replace with your own values in production!

PORT=5000
NODE_ENV=development

# MongoDB Connection String
# For local MongoDB: mongodb://localhost:27017/career-compass
# For MongoDB Atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/career-compass
MONGO_URI=mongodb://localhost:27017/career-compass

# JWT Secret Key (change this in production!)
JWT_SECRET=career-compass-ai-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Optional: OpenAI / AI API Key for real AI responses
# Leave empty to use mock AI mentor responses
AI_API_KEY=

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
